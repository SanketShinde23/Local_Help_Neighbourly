# Backend environment variables (set in Render dashboard)

# Required
MONGO_URI=
JWT_SECRET=

# Email on Render (REQUIRED — SMTP port 587 is blocked on free tier)
# Get API key from: Brevo → Settings → SMTP & API → API Keys
# Must start with xkeysib-  (NOT the SMTP password)
BREVO_API_KEY=xkeysib-xxxxxxxx
EMAIL_FROM=your-verified-sender@yourdomain.com

# Optional — local development only (SMTP works on localhost, not on Render free tier)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_USER=
EMAIL_PASS=
