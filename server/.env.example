# Backend environment variables (set in Render dashboard)

# Required
MONGO_URI=
JWT_SECRET=

# Email — use Brevo HTTP API on Render free tier (SMTP ports 587/465 are blocked)
BREVO_API_KEY=          # Brevo → SMTP & API → API Keys (xkeysib-...)
EMAIL_FROM=             # Verified sender address in Brevo

# Optional SMTP fallback (works locally; blocked on Render free tier)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_USER=
EMAIL_PASS=
